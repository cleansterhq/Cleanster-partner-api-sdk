{
    "name": "cleanster/cleanster-php-sdk",
    "description": "Official PHP SDK for the Cleanster Partner API",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "keywords": ["cleanster", "cleaning", "partner", "api", "sdk"],
    "homepage": "https://github.com/cleanster/cleanster-php-sdk",
    "authors": [
        {
            "name": "Cleanster",
            "email": "partner@cleanster.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Cleanster\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cleanster\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

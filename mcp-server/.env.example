# ─── Cleanster API ────────────────────────────────────────────────────────────
# Base URL for the Cleanster Partner REST API
CLEANSTER_API_BASE_URL=https://partner-sandbox-dot-official-tidyio-project.ue.r.appspot.com/public

# Partner access key — used as the 'access-key' header on every request.
# Required. Obtain from partner@cleanster.com.
CLEANSTER_ACCESS_KEY=your-partner-access-key-here

# User-level auth token — used as the 'token' header on every request.
# Required for user-scoped endpoints. Obtain via POST /v1/user then GET /v1/user/{id}.
# For HTTP/SSE transport the per-connection Bearer token is used instead of this value.
CLEANSTER_TOKEN=your-user-token-here

# ─── MCP Server ───────────────────────────────────────────────────────────────
# Port the HTTP/SSE transport listens on
MCP_SERVER_PORT=8000

# Transport mode: "http" (Express/SSE) or "stdio" (Claude Desktop direct)
MCP_TRANSPORT=http

# ─── Logging ──────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Pretty-print logs in development (set to false in production)
LOG_PRETTY=true

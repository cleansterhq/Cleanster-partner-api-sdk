# ─── Cleanster API ────────────────────────────────────────────────────────────
# Base URL for the Cleanster Partner REST API
CLEANSTER_API_BASE_URL=https://partner-sandbox-dot-official-tidyio-project.ue.r.appspot.com/public

# ─── MCP Server ───────────────────────────────────────────────────────────────
# Port the HTTP/SSE transport listens on
MCP_SERVER_PORT=8000

# Transport mode: "http" (Express/SSE) or "stdio" (Claude Desktop direct)
MCP_TRANSPORT=http

# ─── Logging ──────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Pretty-print logs in development (set to false in production)
LOG_PRETTY=true

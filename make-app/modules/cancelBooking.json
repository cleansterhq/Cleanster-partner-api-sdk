{
  "name": "cancelBooking",
  "label": "Cancel a Booking",
  "description": "Cancels an existing cleaning booking in Cleanster.",
  "connection": "apikey",
  "actionType": "create",
  "url": "/v1/bookings/{{parameters.booking_id}}/cancel",
  "method": "POST",
  "headers": [],
  "qs": [],
  "body": {
    "mode": "json",
    "content": [
      {
        "name": "reason",
        "value": "{{parameters.reason}}"
      }
    ]
  },
  "response": {
    "output": "{{ifempty(body.data, body)}}"
  },
  "parameters": [
    {
      "name": "booking_id",
      "type": "uinteger",
      "label": "Booking ID",
      "help": "The ID of the booking to cancel.",
      "required": true
    },
    {
      "name": "reason",
      "type": "text",
      "label": "Cancellation Reason",
      "help": "Optional reason for the cancellation.",
      "required": false
    }
  ],
  "interface": [
    { "name": "id", "type": "uinteger", "label": "Booking ID" },
    { "name": "status", "type": "text", "label": "Status" },
    { "name": "cancelled_at", "type": "date", "label": "Cancelled At" },
    { "name": "cancellation_reason", "type": "text", "label": "Cancellation Reason" }
  ]
}

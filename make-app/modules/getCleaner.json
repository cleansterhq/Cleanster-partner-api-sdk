{
  "name": "getCleaner",
  "label": "Get a Cleaner",
  "description": "Retrieves a single cleaner by their ID.",
  "connection": "apikey",
  "actionType": "read",
  "typeId": 9,
  "url": "/v1/cleaners/{{parameters.cleaner_id}}",
  "method": "GET",
  "response": {
    "output": "{{ifempty(body.data, body)}}"
  },
  "parameters": [
    {
      "name": "cleaner_id",
      "type": "select",
      "label": "Cleaner",
      "help": "Select the cleaner to retrieve.",
      "required": true,
      "options": {
        "store": "{{rpc('listCleaners')}}"
      }
    }
  ],
  "interface": [
    { "name": "id", "type": "uinteger", "label": "Cleaner ID" },
    { "name": "name", "type": "text", "label": "Name" },
    { "name": "email", "type": "email", "label": "Email" },
    { "name": "phone", "type": "text", "label": "Phone" },
    { "name": "status", "type": "text", "label": "Status" },
    { "name": "rating", "type": "number", "label": "Rating" },
    { "name": "total_jobs", "type": "uinteger", "label": "Total Jobs Completed" },
    { "name": "address", "type": "text", "label": "Address" },
    { "name": "city", "type": "text", "label": "City" },
    { "name": "state", "type": "text", "label": "State" },
    { "name": "created_at", "type": "date", "label": "Member Since" }
  ]
}

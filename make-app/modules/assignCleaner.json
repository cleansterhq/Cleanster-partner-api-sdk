{
  "name": "assignCleaner",
  "label": "Assign Cleaner to Booking",
  "description": "Assigns a specific cleaner to an existing booking.",
  "connection": "apikey",
  "actionType": "create",
  "url": "/v1/bookings/{{parameters.booking_id}}/assign-cleaner",
  "method": "POST",
  "headers": [],
  "qs": [],
  "body": {
    "mode": "json",
    "content": [
      {
        "name": "cleaner_id",
        "value": "{{parameters.cleaner_id}}"
      }
    ]
  },
  "response": {
    "output": "{{ifempty(body.data, body)}}"
  },
  "parameters": [
    {
      "name": "booking_id",
      "type": "uinteger",
      "label": "Booking ID",
      "help": "The ID of the booking to assign a cleaner to.",
      "required": true
    },
    {
      "name": "cleaner_id",
      "type": "select",
      "label": "Cleaner",
      "help": "Select the cleaner to assign to this booking.",
      "required": true,
      "options": {
        "store": "{{rpc('listCleaners')}}"
      }
    }
  ],
  "interface": [
    { "name": "id", "type": "uinteger", "label": "Booking ID" },
    { "name": "status", "type": "text", "label": "Status" },
    { "name": "cleaner_id", "type": "uinteger", "label": "Cleaner ID" },
    { "name": "cleaner_name", "type": "text", "label": "Cleaner Name" },
    { "name": "cleaner_email", "type": "email", "label": "Cleaner Email" },
    { "name": "assigned_at", "type": "date", "label": "Assigned At" }
  ]
}
